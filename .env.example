# Desk5 Environment — Copy this file to .env and fill in your values
# Never commit .env to git!
#
# JOIN HYPERLIQUID (required):
#   https://app.hyperliquid.xyz/join/TRADEDESK5
#   Use the referral code TRADEDESK5 — it helps fund continued development.
#
# ⚠️  UNIFIED ACCOUNT WARNING:
#   Hyperliquid uses a UNIFIED account by default for balances under $50,000.
#   Your SPOT USDC and PERP margin are the SAME balance. You do NOT transfer
#   between them. If you create a subaccount, things get weird. Don't argue
#   about this unless you've actually read the docs.
#
# ================================================================

# ── Hyperliquid API Key (private key, hex format, no 0x prefix) ──
# This is your wallet private key. It must match the address you deposit to.
# Generate a fresh wallet in MetaMask/Phantom, deposit USDC, paste key here.
HL_API_KEY=your_private_key_here_without_0x

# ── Your Hyperliquid wallet address (must match the key above) ──
HL_ADDRESS=0xYourAddressHere

# ── Solana public address (optional — for deposit QR code display) ──
DESK_SOLANA_ADDRESS=your_solana_public_address

# ── Telegram alerts (optional — leave empty to disable) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── On-chain treasury monitoring (optional) ──
# Configure a treasury address to watch for token outflows via Etherscan.
# TREASURY_ADDR=0xYourTreasuryHere
# TOKEN_CONTRACT=0xYourTokenContractHere
# TOKEN_SYMBOL=YOURTOKEN
# WASHER_ADDRS=0xaddr1,0xaddr2

# ── Trading mode ──
LIVE_MODE=true
